<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Maui.Canvas.Views.StudentManagementView"
             Title="Manage Students">

    <ScrollView>
        <VerticalStackLayout Spacing="15" Padding="20">

            <Label Text="Manage Students" FontSize="26" FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <CollectionView ItemsSource="{Binding Students}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BorderColor="Gray" Padding="12" Margin="0,4">
                            <Grid ColumnDefinitions="*,Auto,Auto">
                                <VerticalStackLayout Grid.Column="0">
                                    <Label Text="{Binding Name}" FontSize="16" FontAttributes="Bold" />
                                    <Label Text="{Binding Classification}" FontSize="13" />
                                </VerticalStackLayout>
                                <Button Grid.Column="1" Text="Edit" Clicked="OnEditStudent" />
                                <Button Grid.Column="2" Text="Remove" Clicked="OnRemoveStudent" />
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label Text="Add a Student" FontSize="18" FontAttributes="Bold" />
            <Entry x:Name="NewStudentName" Placeholder="Name" />
            <Entry x:Name="NewStudentClassification" Placeholder="Classification (e.g. Junior)" />
            <Button Text="Add Student" Clicked="OnAddStudent" />

            <Button Text="Back to Main Menu" Clicked="OnBackClicked" />
            <Button Text="Main Menu" Clicked="OnMainMenuClicked" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>