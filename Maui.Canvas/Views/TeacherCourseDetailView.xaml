<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Maui.Canvas.Views.TeacherCourseDetailView"
             Title="Manage Course">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20">

            <Label Text="{Binding CourseTitle}" FontSize="26" FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <Label Text="Enrolled Students" FontSize="20" FontAttributes="Bold" />
            <CollectionView ItemsSource="{Binding Roster}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BorderColor="Gray" Padding="12" Margin="0,4">
                            <Grid ColumnDefinitions="*,Auto">
                                <VerticalStackLayout Grid.Column="0">
                                    <Label Text="{Binding Name}" FontSize="16" FontAttributes="Bold" />
                                    <Label Text="{Binding Classification}" FontSize="13" />
                                </VerticalStackLayout>
                                <Button Grid.Column="1" Text="Remove" Clicked="OnRemoveClicked" />
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label Text="Add a Student" FontSize="20" FontAttributes="Bold" />
            <CollectionView ItemsSource="{Binding AvailableToAdd}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BorderColor="Gray" Padding="12" Margin="0,4">
                            <Grid ColumnDefinitions="*,Auto">
                                <VerticalStackLayout Grid.Column="0">
                                    <Label Text="{Binding Name}" FontSize="16" FontAttributes="Bold" />
                                    <Label Text="{Binding Classification}" FontSize="13" />
                                </VerticalStackLayout>
                                <Button Grid.Column="1" Text="Add" Clicked="OnAddClicked" />
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
            <Label Text="Assignments" FontSize="20" FontAttributes="Bold" />
            <CollectionView ItemsSource="{Binding Assignments}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BorderColor="Gray" Padding="12" Margin="0,4">
                            <Grid ColumnDefinitions="*,Auto,Auto">
                                <VerticalStackLayout Grid.Column="0">
                                    <Label Text="{Binding Name}" FontSize="16" FontAttributes="Bold" />
                                    <Label Text="{Binding AvailablePoints, StringFormat='{0} pts'}" FontSize="13" />
                                    <Label Text="{Binding DueDate, StringFormat='Due {0:MM/dd/yyyy}'}" FontSize="12" />
                                </VerticalStackLayout>
                                <Button Grid.Column="1" Text="Edit" Clicked="OnEditAssignment" />
                                <Button Grid.Column="2" Text="Delete" Clicked="OnDeleteAssignment" />
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label Text="Add an Assignment" FontSize="18" FontAttributes="Bold" />
            <Entry x:Name="NewAssignmentName" Placeholder="Assignment name" />
            <Entry x:Name="NewAssignmentPoints" Placeholder="Available points" Keyboard="Numeric" />
            <DatePicker x:Name="NewAssignmentDue" />
            <Button Text="Add Assignment" Clicked="OnAddAssignment" />

            <Button Text="Back" Clicked="OnBackClicked" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>