<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Maui.Canvas.Views.TeacherCourseDetailView"
             Title="Manage Course">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20">

            <Label Text="{Binding CourseTitle}" FontSize="26" FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <Label Text="Enrolled Students" FontSize="20" FontAttributes="Bold" />
            <CollectionView ItemsSource="{Binding Roster}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BorderColor="Gray" Padding="12" Margin="0,4">
                            <Grid ColumnDefinitions="*,Auto">
                                <VerticalStackLayout Grid.Column="0">
                                    <Label Text="{Binding Name}" FontSize="16" FontAttributes="Bold" />
                                    <Label Text="{Binding Classification}" FontSize="13" />
                                </VerticalStackLayout>
                                <Button Grid.Column="1" Text="Remove" Clicked="OnRemoveClicked" />
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label Text="Add a Student" FontSize="20" FontAttributes="Bold" />
            <CollectionView ItemsSource="{Binding AvailableToAdd}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BorderColor="Gray" Padding="12" Margin="0,4">
                            <Grid ColumnDefinitions="*,Auto">
                                <VerticalStackLayout Grid.Column="0">
                                    <Label Text="{Binding Name}" FontSize="16" FontAttributes="Bold" />
                                    <Label Text="{Binding Classification}" FontSize="13" />
                                </VerticalStackLayout>
                                <Button Grid.Column="1" Text="Add" Clicked="OnAddClicked" />
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button Text="Back" Clicked="OnBackClicked" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>