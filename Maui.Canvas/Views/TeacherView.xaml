<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Maui.Canvas.Views.TeacherView"
             Title="Teacher">

    <VerticalStackLayout Spacing="15" Padding="20">

        <Label Text="Select a Course" FontSize="28" HorizontalOptions="Center" />

        <CollectionView ItemsSource="{Binding Courses}"
                        SelectionMode="Single"
                        SelectionChanged="OnCourseSelected">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BorderColor="Gray" Padding="15" Margin="0,5">
                        <VerticalStackLayout>
                            <Label Text="{Binding Name}" FontSize="18" FontAttributes="Bold" />
                            <Label Text="{Binding Code}" FontSize="14" />
                            <Label Text="{Binding Semester}" FontSize="12" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Text="Manage Students" Clicked="OnManageStudents" />

        <Button Text="Back to Main Menu" Clicked="OnBackClicked" />

    </VerticalStackLayout>
</ContentPage>